pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/MUTTANNA-S-G/demo-project.git'
            }
        }

        stage('Build') {
            steps {
                bat 'mvn clean package'
            }
        }

        stage('Test') {
            steps {
                bat 'mvn test'
            }
        }
    }

    post {
        always {
            junit 'target/surefire-reports/*.xml'

            // ✅ Archive JAR file
            archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
        }
    }
}
